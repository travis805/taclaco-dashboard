# Turso connection secrets for taclaco-dashboard.
# Copy this file to .streamlit/secrets.toml and fill in the real values.
# NEVER commit secrets.toml to git. It is listed in .gitignore.
#
# Get these values from:
#   turso db show taclaco --url
#   turso db tokens create taclaco
#
TURSO_DATABASE_URL = "libsql://taclaco-<org>.turso.io"
TURSO_AUTH_TOKEN   = "your-auth-token-here"

# Passphrase gating the public Streamlit Cloud app. Leave unset for open local dev.
APP_PASSWORD        = "choose-a-passphrase"
